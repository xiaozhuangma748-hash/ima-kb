# ===== LLM API（Agnes AI）=====
# 申请地址：联系管理员获取 API Key
AGNES_API_KEY=sk-在这里填入你的key
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
LLM_MODEL=agnes-2.0-flash

# ===== 存储路径 =====
# 默认在项目根目录的 storage/ 下
STORAGE_PATH=./storage

# ===== 分块参数 =====
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ===== RAG 参数 =====
RAG_TOP_K=6
LLM_MAX_TOKENS=1024

# ===== 对话记忆 =====
# 进入 LLM prompt 的最近消息条数（1 轮 = 2 条）
HISTORY_WINDOW=16
# 触发摘要压缩的阈值
HISTORY_COMPRESS_THRESHOLD=24
# 是否启用历史感知检索（1=启用，0=关闭）
HISTORY_AWARE_RETRIEVAL=1
# 是否启用跨会话记忆自动提取（1=启用，0=关闭）
ENABLE_CROSS_SESSION_EXTRACT=1
