# ===== LLM API（Agnes AI）=====
# 申请地址：联系管理员获取 API Key
AGNES_API_KEY=sk-在这里填入你的key
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
LLM_MODEL=agnes-2.0-flash

# ===== 存储路径 =====
# 默认在项目根目录的 storage/ 下
STORAGE_PATH=./storage

# ===== 分块参数 =====
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ===== RAG 参数 =====
RAG_TOP_K=6
LLM_MAX_TOKENS=1024
